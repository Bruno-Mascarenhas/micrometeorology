# ==============================================================================
# Python / Build / OS
# ==============================================================================
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
*.whl
.eggs/
.DS_Store
Thumbs.db

# ==============================================================================
# Environment & Secrets
# ==============================================================================
.env
.env.local
.env.*
!.env.example

# ==============================================================================
# Virtual Environments
# ==============================================================================
.venv/
venv/
env/

# ==============================================================================
# Testing & Coverage
# ==============================================================================
.coverage
htmlcov/
coverage.xml
*.log

# ==============================================================================
# Caching & Temp Files
# ==============================================================================
.mypy_cache/
.ruff_cache/
.uv-cache/
.pytest_cache/
.pytest_tmp*/
scratch/
.ipynb_checkpoints/
.jupyter/
# Generated by `make audit` / the CI vulnerability gate
requirements-audit.txt
# Ad-hoc tool output dumps (mypy_output.txt and friends) never belong in git
*_output.txt

# ==============================================================================
# IDE / Editor (Local only)
# ==============================================================================
# Ignore IDE folders except intentionally shared workspace settings
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
.idea/
.claude/
*.swp
*.swo
*~

# ==============================================================================
# Data Files (Raw / Temporary / Large)
# ==============================================================================
/data/
/logs/
/runs/
/tb_logs/
*.nc
*.nc4
*.hdf
*.hdf5
/data/**/*.dat
# All-sky camera videos (also under /data, but stray copies land elsewhere too,
# e.g. Colab /content) — one-day timelapses are large binaries.
*.mp4

# ==============================================================================
# ML / Experiment Artifacts
# ==============================================================================
/output/
*.pt
*.pth
*.ckpt
*.joblib
*.pkl
# Precomputed visual-embedding shards (allsky multimodal pipeline). These live
# under /output today but are ignored globally so scratch/exported shards never
# get committed.
*.safetensors


# ==============================================================================
# Output Images
# ==============================================================================
# Prevent accidental tracking of generated map figures
/output/**/*.jpg
/output/**/*.jpeg
/output/**/*.png
/output/**/*.gif
/output/**/*.bmp
